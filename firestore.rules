rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Règles simplifiées pour permettre l'évolution de l'app (nouveaux champs commme terrain, etc.)
    match /teams/{teamId} {
      allow read, write: if true;
    }

    match /matches/{matchId} {
      allow read, write: if true;
    }

    match /state/main {
      allow read, write: if true;
    }

    match /tv/{docId} {
      allow read, write: if true;
    }
  }
}
// test
